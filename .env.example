# Example environment variables for bantar-web
# API base URL used when running with VITE_APP_ENV=prod (e.g. https://api.example.com).
# If empty, the dev proxy (http://localhost:8080) will be used for /api during local development.
VITE_API_URL=
# Set this to 'prod' to use the production proxy (uses VITE_API_URL).
VITE_APP_ENV=local
# Comma-separated list of allowed hosts for the Vite dev server.
# Required when VITE_APP_ENV=prod (e.g. example.com,api.example.com).
VITE_ALLOWED_HOSTS=
